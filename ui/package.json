{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.js",
  "homepage": "./",
  "build": {
    "appId": "com.fluxvpn.ipv7",
    "productName": "FluxVPN IPv7",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.js"
    ],
    "win": {
      "target": "zip",
      "icon": "public/icon.ico",
      "forceCodeSigning": false
    },
    "publish": null
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron electron.js",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron electron.js\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "eventsource": "^4.1.0",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
